{
  "name": "copilot-coding-agents",
  "version": "0.1.0",
  "description": "Turn GitHub Copilot into OpenAI/Anthropic API compatible server. Usable with Claude Code!",
  "keywords": [
    "proxy",
    "github-copilot",
    "openai-compatible"
  ],
  "homepage": "https://github.com/justyining/copilot-api-proxy",
  "bugs": "https://github.com/justyining/copilot-api-proxy/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justyining/copilot-api-proxy.git"
  },
  "author": "Ning Yi <eathning@gmail.com>",
  "type": "module",
  "bin": {
    "claude-copilot": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "auth": "bun run ./src/main.ts -- auth",
    "build": "tsdown",
    "check-usage": "bun run ./src/main.ts -- check-usage",
    "debug": "bun run ./src/main.ts -- debug",
    "dev": "bun run --watch ./src/main.ts -- __serve --port 4141",
    "dev:claude": "ANTHROPIC_BASE_URL=http://localhost:4141 ANTHROPIC_AUTH_TOKEN=dummy ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4.6 ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4.6 ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4.5 CLAUDE_CODE_DISABLE_1M_CONTEXT=1 CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 claude",
    "knip": "knip-bun",
    "launch": "bun run ./src/main.ts",
    "lint": "eslint --cache",
    "lint:all": "eslint --cache .",
    "prepack": "bun run build",
    "pack:target": "bun run scripts/pack.ts",
    "prepare": "simple-git-hooks",
    "release": "bumpp && bun publish --access public",
    "typecheck": "tsc"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "*": "bun run lint --fix"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "clipboardy": "^5.0.0",
    "consola": "^3.4.2",
    "fetch-event-stream": "^0.1.5",
    "gpt-tokenizer": "^3.0.1",
    "hono": "^4.9.9",
    "proxy-from-env": "^1.1.0",
    "srvx": "^0.8.9",
    "tiny-invariant": "^1.3.3",
    "undici": "^7.16.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@echristian/eslint-config": "^0.0.54",
    "@types/bun": "^1.2.23",
    "@types/proxy-from-env": "^1.0.4",
    "bumpp": "^10.2.3",
    "eslint": "^9.37.0",
    "knip": "^5.64.1",
    "lint-staged": "^16.2.3",
    "prettier-plugin-packagejson": "^2.5.19",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.15.6",
    "typescript": "^5.9.3"
  }
}
