#!/usr/bin/env bash
# Claude Code wrapper for copilot-api
# Usage: claude-copilot [any claude args...]
#
# Install:
#   curl -fsSL https://raw.githubusercontent.com/justyining/copilot-api/master/claude-copilot -o ~/.local/bin/claude-copilot && chmod +x ~/.local/bin/claude-copilot

export ANTHROPIC_AUTH_TOKEN="${ANTHROPIC_AUTH_TOKEN:-yougotthekey}"
export ANTHROPIC_BASE_URL="${ANTHROPIC_BASE_URL:-http://localhost:4141}"
export ANTHROPIC_DEFAULT_OPUS_MODEL="${ANTHROPIC_DEFAULT_OPUS_MODEL:-claude-opus-4.7}"
export ANTHROPIC_DEFAULT_SONNET_MODEL="${ANTHROPIC_DEFAULT_SONNET_MODEL:-claude-sonnet-4.6}"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="${ANTHROPIC_DEFAULT_HAIKU_MODEL:-claude-haiku-4.5}"
export CLAUDE_CODE_DISABLE_1M_CONTEXT="${CLAUDE_CODE_DISABLE_1M_CONTEXT:-1}"
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="${CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC:-1}"

exec claude "$@"
